# gdev-content — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=stub                    # stub | anthropic
ANTHROPIC_API_KEY=sk-ant-...         # required when LLM_PROVIDER=anthropic

# ── Prompt version ────────────────────────────────────────────────────────────
PROMPT_VERSION=v1.0                  # resolves prompts/{stage}_v1.0.txt

# ── Webhook server ────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me             # X-Webhook-Secret header value; required
FASTAPI_PORT=8000

# ── Pipeline tuning ───────────────────────────────────────────────────────────
PIPELINE_MAX_REWRITES=2              # max automatic rewrite attempts before ESCALATE
